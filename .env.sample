# Copy to .env and fill in values. Used by `uv run run.py` (see run.py --help).

# --- API keys (set the one matching your MODEL provider) ---
OPENAI_API_KEY=your-api-key
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# CEREBRAS_API_KEY=
# AZURE_API_KEY=
# AZURE_API_BASE=
# AZURE_API_VERSION=

# --- Local LM Studio (OpenAI-compatible server) ---
# Required when MODEL starts with lm_studio/ — LiteLLM reads these automatically.
LM_STUDIO_API_BASE=http://localhost:1234/v1/
LM_STUDIO_API_KEY=EMPTY

# --- Model ID (required) ---
# LiteLLM expects: <provider>/<model-id-sent-to-that-api>
# The prefix selects routing and which env vars apply. A bare name like gpt-4o
# may work for OpenAI defaults, but qwen/... without a provider will fail.
# Use the exact id from your provider (e.g. LM Studio GET /v1/models).
#
# Display name in results is separate: --model-alias my-label@quant
#
MODEL=openai/gpt-4o

# Provider examples (uncomment one; set matching API key / base above):
#
# openai/gpt-4o
# openai/gpt-4o-mini
# openai/o3-mini
# anthropic/claude-sonnet-4-20250514
# gemini/gemini-2.5-flash
# deepseek/deepseek-reasoner
# mistral/mistral-medium-2505
# cerebras/qwen-3-32b
# azure/o4-mini-2025-04-16
# xai/grok-3-mini-beta
# lm_studio/qwen/qwen3.6-35b-a3b
# lm_studio/microsoft_phi-4-reasoning-plus
#
# OpenAI-compatible custom base without lm_studio/ prefix:
#   MODEL=openai/your-local-model-id
#   plus: uv run run.py --litellm-params '{"api_base":"http://localhost:1234/v1/","api_key":"EMPTY"}'
